<?xml version="1.0" encoding="utf-8"?>
<!--
  Notification status-bar icon. Must be a single-colour silhouette
  (Android tints it white in the status bar and uses it as the small
  icon throughout the notification shade). Same teardrop geometry as
  the launcher monochrome so the brand reads consistently.

  Sized 24×24 because that's what the status bar renders at — any
  detail finer than this gets antialiased to mush.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?android:attr/colorAccent">
    <!-- Teardrop body — closed evenOdd shape with a play-button cutout.
         Same path topology as drawable/ic_launcher_monochrome.xml,
         scaled into the 24x24 viewport. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M12,3
                           C12,3 6.9,9.8 6.9,14.7
                           C6.9,18 9.1,21 12,21
                           C14.9,21 17.1,18 17.1,14.7
                           C17.1,9.8 12,3 12,3 Z
                           M12,11
                           m-3.5,0
                           a3.5,3.5 0 1,0 7,0
                           a3.5,3.5 0 1,0 -7,0 Z"/>
    <!-- Play triangle inside the cutout -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M10.8,9.4
                          L13.7,11.1
                          C14.1,11.3 14.1,11.7 13.7,11.95
                          L10.8,13.6
                          C10.4,13.85 9.95,13.6 9.95,13.1
                          L9.95,9.9
                          C9.95,9.4 10.4,9.15 10.8,9.4 Z"/>
</vector>
