<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BeatDrop" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!--
          Splash background. Matches the in-app SplashScreen.kt exactly
          so the Android-12+ system splash → branded Compose splash
          handover is a single continuous colour, no jarring swap.

          We use a deep midnight indigo (#0E0A1F) chosen specifically
          to complement the new gold/violet/coral logo gradient — the
          warm logo glows against the cool indigo. Was previously
          #151025 (purple-leaning); shifted slightly bluer so the
          coral and gold endpoints of the logo gradient have maximum
          chromatic separation from the backdrop.
        -->
        <item name="android:windowBackground">#0E0A1F</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">#0E0A1F</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/beatdrop_logo</item>
        <!--
          Suppress the icon-background ring on Android 12L+ so the logo
          appears flat against the splash background, identical to how
          it renders in SplashScreen.kt.
        -->
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="v">#0E0A1F</item>
    </style>
</resources>
