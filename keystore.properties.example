# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit the real file.
#
# Without this file (or the equivalent env vars KEYSTORE_FILE, KEYSTORE_PASSWORD,
# KEY_ALIAS, KEY_PASSWORD), release builds fall back to the debug keystore.
# If the debug keystore is absent (CI / fresh machine), the APK will be unsigned
# and Android will refuse to install it with "There was a problem parsing the package."

storeFile=/absolute/path/to/your/release.jks
storePassword=your_keystore_password
keyAlias=your_key_alias
keyPassword=your_key_password
